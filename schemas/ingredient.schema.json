{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/longevity-skills/schemas/ingredient.schema.json",
  "title": "Ingredient Profile",
  "description": "Enriched ingredient profile combining per-book claims with web research and culinary data. One profile may aggregate claims from multiple source books. Each claim carries its book_slug so provenance is preserved.",
  "type": "object",
  "required": ["name", "slug", "category", "book_claims", "source_books", "research_status"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the ingredient"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-safe kebab-case identifier"
    },
    "category": {
      "type": "string",
      "enum": [
        "fish",
        "vegetable",
        "fruit",
        "grain",
        "legume",
        "nut",
        "seed",
        "oil",
        "dairy",
        "egg",
        "meat",
        "supplement",
        "nutrient",
        "beverage",
        "spice",
        "herb",
        "mushroom",
        "shellfish",
        "other"
      ],
      "description": "Single-word category. Must match the enum in research-ingredient/enrich.py."
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other names for this ingredient (different books may call it different things)"
    },
    "source_books": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "description": "Denormalized list of book_slugs that cite this ingredient. Recomputed on every write from book_claims[].book_slug. Sorted and deduplicated."
    },
    "book_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "mechanism", "confidence", "book_slug"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The health claim text"
          },
          "mechanism": {
            "type": "string",
            "description": "Biological mechanism of action"
          },
          "recommendation": {
            "type": ["string", "null"],
            "description": "Per-claim dosing/preparation guidance, if any. Nullable for legacy claims without this field."
          },
          "reference": {
            "type": "string",
            "description": "Study, citation, or 'book-assertion'"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "book_slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "Which book this claim came from. Required — drives source_books[] derivation and conflict surfacing."
          }
        }
      }
    },
    "supplementary_research": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "finding"],
        "properties": {
          "source": {
            "type": "string",
            "description": "PubMed, Examine, or other source name"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "finding": {
            "type": "string"
          },
          "agrees_with_book": {
            "type": "boolean",
            "description": "Whether the web finding agrees with the book claim(s). When an ingredient is cited by multiple books, this reflects agreement with the dominant claim direction; cross-book disagreement is captured by claims with different book_slug and different mechanism."
          }
        }
      }
    },
    "flavor_profile": {
      "type": "object",
      "properties": {
        "taste": {
          "type": "array",
          "items": { "type": "string" }
        },
        "aroma": {
          "type": "array",
          "items": { "type": "string" }
        },
        "texture": {
          "type": "array",
          "items": { "type": "string" }
        },
        "culinary_category": {
          "type": "string",
          "description": "e.g. 'spice', 'leafy green', 'legume'"
        }
      }
    },
    "culinary_pairings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ingredient"],
        "properties": {
          "ingredient": { "type": "string" },
          "tradition": {
            "type": "string",
            "description": "Culinary tradition, e.g. 'Indian', 'Japanese'"
          },
          "source": {
            "type": "string",
            "description": "Chef name or cookbook"
          }
        }
      }
    },
    "seasonality": {
      "type": "string"
    },
    "nutrient_highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["compound"],
        "properties": {
          "compound": { "type": "string" },
          "amount_per_100g": { "type": "string" },
          "bioavailability_notes": { "type": "string" }
        }
      }
    },
    "synergies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["with", "type"],
        "properties": {
          "with": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["synergy", "antagonism", "complement"]
          },
          "note": { "type": "string" }
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "last_researched": {
      "type": "string",
      "format": "date-time",
      "description": "When web research was last fetched"
    },
    "research_status": {
      "type": "string",
      "enum": ["complete", "partial", "book-only"]
    },
    "migration_version": {
      "type": "integer",
      "description": "Set by scripts/migrate-multi-book.py when the profile is migrated from the legacy singular-source_book shape. Used as an idempotency marker."
    }
  }
}
