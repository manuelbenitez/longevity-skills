{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/longevity-skills/schemas/book-extract.schema.json",
  "title": "Book Extract",
  "description": "Structured extraction of food/ingredient claims from a book chapter. Multi-book aware: every chapter carries explicit book identity so downstream skills can attribute claims correctly across multiple source books.",
  "type": "object",
  "required": ["book", "author", "book_slug", "chapter", "ingredients"],
  "properties": {
    "book": {
      "type": "string",
      "description": "Book title, e.g. 'The Path to Longevity'"
    },
    "author": {
      "type": "string",
      "description": "Author full name, e.g. 'Luigi Fontana'"
    },
    "book_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable kebab-case identifier from data/book-raw/<slug>/_book.json. Never re-derive; always read from the manifest."
    },
    "chapter": {
      "type": "string",
      "description": "Chapter title"
    },
    "chapter_number": {
      "type": "integer",
      "description": "Chapter number, optional"
    },
    "page_range": {
      "type": "string",
      "description": "Page range covered, e.g. '45-72'"
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "When extraction was performed"
    },
    "extraction_status": {
      "type": "string",
      "enum": ["complete", "partial", "draft"],
      "description": "Whether this extract is finished"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "slug", "claims"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Ingredient name as it appears in the book"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
            "description": "URL-safe kebab-case identifier"
          },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Other names this ingredient is called in this book"
          },
          "page_refs": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Page numbers where this ingredient is discussed"
          },
          "claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "mechanism", "confidence"],
              "properties": {
                "text": {
                  "type": "string",
                  "description": "The specific health claim, in the book's own framing"
                },
                "mechanism": {
                  "type": "string",
                  "description": "Biological mechanism of action"
                },
                "recommendation": {
                  "type": ["string", "null"],
                  "description": "Actionable dosing/preparation guidance attached to this claim, if any. Nullable for claims with no actionable component."
                },
                "reference": {
                  "type": "string",
                  "description": "Study, citation, or 'book-assertion' if the book offers no external source"
                },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"],
                  "description": "Evidence quality: high (multiple studies), medium (one study or strong mechanism), low (book assertion without cited study)"
                }
              }
            }
          },
          "consumption": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "string",
                "description": "Recommended amount, e.g. '1 cup daily'"
              },
              "frequency": {
                "type": "string",
                "description": "How often, e.g. 'daily', '3x/week'"
              },
              "preparation": {
                "type": "string",
                "description": "Recommended preparation method, e.g. 'cooked, not raw'"
              },
              "reasoning": {
                "type": "string",
                "description": "Why this amount/method is recommended"
              }
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["with", "type"],
              "properties": {
                "with": {
                  "type": "string",
                  "description": "Name of the related ingredient (natural name, normalized post-extraction)"
                },
                "type": {
                  "type": "string",
                  "enum": ["synergy", "antagonism", "complement"]
                },
                "note": {
                  "type": "string",
                  "description": "How this ingredient interacts with the target"
                }
              }
            }
          }
        }
      }
    }
  }
}
